[{"data":1,"prerenderedAt":314},["ShallowReactive",2],{"content-\u002Fblog\u002Fbook-user-friendly":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"keywords":10,"robots":10,"date":11,"image":12,"tags":13,"body":16,"_type":308,"_id":309,"_source":310,"_file":311,"_stem":312,"_extension":313},"\u002Fblog\u002Fbook-user-friendly","blog",false,"","《我們的行為是怎樣被設計的》在機器與行為之間，編排一場人性的對話","前陣子剛讀完《我們的行為是怎樣被設計的》，我對「設計」這兩個字的理解被徹底重組，並給了我一個全新的視角：設計不是為了解決功能問題，而是為了解決「人與科技如何共存」的信任問題。","我們的行為是怎樣被設計的, UI\u002FUX, 產品設計","2026-04-12","\u002Fimages\u002Farticle\u002Farticle_book-user-friendly.png",[14,15],"產品設計","心理學",{"type":17,"children":18,"toc":297},"root",[19,26,30,37,42,98,104,113,118,141,147,157,180,186,194,199,232,238,243,266,271,278],{"type":20,"tag":21,"props":22,"children":23},"element","p",{},[24],{"type":25,"value":9},"text",{"type":20,"tag":27,"props":28,"children":29},"hr",{},[],{"type":20,"tag":31,"props":32,"children":34},"h2",{"id":33},"我們對機器的期待其實很擬人",[35],{"type":25,"value":36},"我們對機器的期待，其實很「擬人」",{"type":20,"tag":21,"props":38,"children":39},{},[40],{"type":25,"value":41},"書中指出「我們對機器的期待，非常符合我們對真人的期待」。就像當我們在執行複雜的 AI 自動化工作流程時，我們下意識會希望機器能「感應」到我們的意圖",{"type":20,"tag":43,"props":44,"children":45},"ul",{},[46,58,68,78,88],{"type":20,"tag":47,"props":48,"children":49},"li",{},[50,56],{"type":20,"tag":51,"props":52,"children":53},"strong",{},[54],{"type":25,"value":55},"心智模型（Mental Model）",{"type":25,"value":57},"：使用者不是在學功能，而是在建立對機器的想像。如果機器做得比你好，但做法跟你完全不同，那種「摩擦力」就是挫折感的來源。",{"type":20,"tag":47,"props":59,"children":60},{},[61,66],{"type":20,"tag":51,"props":62,"children":63},{},[64],{"type":25,"value":65},"社交禮貌",{"type":25,"value":67},"：產品不只是賣功能，而是一種社交。如果產品實現的跟我們想要的完全不同、沒有即時回饋，或在錯誤的時間打斷使用者，這在心理學上就是一種「失禮」。",{"type":20,"tag":47,"props":69,"children":70},{},[71,76],{"type":20,"tag":51,"props":72,"children":73},{},[74],{"type":25,"value":75},"信任累積在小事中",{"type":25,"value":77},"：就像人際關係一樣，機器的可靠性不是來自大功能，要讓人信任機器，必須讓人類感覺「機器知道我想做什麼」。這種安全感來自於精準的回饋機制，它像肢體語言一樣，在非字詞的層次上與使用者溝通。",{"type":20,"tag":47,"props":79,"children":80},{},[81,86],{"type":20,"tag":51,"props":82,"children":83},{},[84],{"type":25,"value":85},"彌補心智模型的不足",{"type":25,"value":87},"：當產品的回饋不足或邏輯（心智模型）太過複雜時，適當的情感連結（Emotional Connection）能成為最好的救火隊。",{"type":20,"tag":47,"props":89,"children":90},{},[91,96],{"type":20,"tag":51,"props":92,"children":93},{},[94],{"type":25,"value":95},"情感的高低起伏",{"type":25,"value":97},"：書中建議將產品歷程視為一場「談戀愛」。一段完整的關係不該是一條平淡的直線，而應該有情感的高低起伏與驚喜，以峰終定律來說更能增加產品的記憶點。這種情感上的滿足感，往往能讓使用者忽略技術上的微小瑕疵，與產品建立更深層的信任。",{"type":20,"tag":31,"props":99,"children":101},{"id":100},"隱喻是科技的降落傘讓陌生變得安全",[102],{"type":25,"value":103},"隱喻是科技的「降落傘」：讓陌生變得安全",{"type":20,"tag":105,"props":106,"children":107},"blockquote",{},[108],{"type":20,"tag":21,"props":109,"children":110},{},[111],{"type":25,"value":112},"發明任何東西，一定要用隱喻或透過隱喻來思考，隱喻是事物變美的關鍵。",{"type":20,"tag":21,"props":114,"children":115},{},[116],{"type":25,"value":117},"書中提到在我們的生活中，處處充滿會使我們感受擬人化的事物：看似人類表情的汽車車頭燈、前傾彷彿微笑歡迎的麥金塔電腦，結合擬人化的情感設計更使人與產品拉近距離",{"type":20,"tag":43,"props":119,"children":120},{},[121,131],{"type":20,"tag":47,"props":122,"children":123},{},[124,129],{"type":20,"tag":51,"props":125,"children":126},{},[127],{"type":25,"value":128},"橋接新舊世界",{"type":25,"value":130},"：設計師的工作就像是在冰冷的數位邏輯與人類的物理經驗間搭橋。為什麼第一代電腦要模仿「桌面」？因為我們需要熟悉的隱喻來克服對未知的恐懼，初期設計時可以藉由情緒版（mood board）釐清抽象情緒，並讓用戶喚起對某些事物的感受。",{"type":20,"tag":47,"props":132,"children":133},{},[134,139],{"type":20,"tag":51,"props":135,"children":136},{},[137],{"type":25,"value":138},"隱喻的演進",{"type":25,"value":140},"：雖然隱喻會隨著時間「死去」變成語言的一部分（如：存檔圖示是磁碟片），但它讓技術降落在人類的直覺上，當物理世界的舊隱喻失效時，我們如何創造新的行為模式，讓事情「不假思索」地發生？",{"type":20,"tag":31,"props":142,"children":144},{"id":143},"包容設計障礙不是人的問題是設計的問題",[145],{"type":25,"value":146},"包容設計：障礙不是人的問題，是「設計」的問題",{"type":20,"tag":21,"props":148,"children":149},{},[150,152],{"type":25,"value":151},"書中給了設計師一個沉重的社會責任：",{"type":20,"tag":51,"props":153,"children":154},{},[155],{"type":25,"value":156},"「大多數人口中的殘缺，其實是設計的問題。」",{"type":20,"tag":43,"props":158,"children":159},{},[160,170],{"type":20,"tag":47,"props":161,"children":162},{},[163,168],{"type":20,"tag":51,"props":164,"children":165},{},[166],{"type":25,"value":167},"邊緣設計的價值",{"type":25,"value":169},"：如果我們只為「理想中的正常人」設計，那其實是設計師的懶惰。以通用設計的概念，當我們開始考慮人類的極限、缺陷與容易出錯的本質，設計出的成品反而會對所有人（包含大眾）都更好用。",{"type":20,"tag":47,"props":171,"children":172},{},[173,178],{"type":20,"tag":51,"props":174,"children":175},{},[176],{"type":25,"value":177},"看見未來的人",{"type":25,"value":179},"：設計師被定義為「不能通靈，卻能看見未來的人」。我們的工作是重塑問題，並在事物發生前，就為未來的生活方式定調。",{"type":20,"tag":31,"props":181,"children":183},{"id":182},"零阻力的未來按鈕時代的終結",[184],{"type":25,"value":185},"零阻力的未來：按鈕時代的終結",{"type":20,"tag":105,"props":187,"children":188},{},[189],{"type":20,"tag":21,"props":190,"children":191},{},[192],{"type":25,"value":193},"容易和簡單並非一模一樣，探索什麼是真正簡單的東西，並付諸行動，是非常艱難的任務 ——杜威 John Dewey 經驗與教育 Experience and Education",{"type":20,"tag":21,"props":195,"children":196},{},[197],{"type":25,"value":198},"當科技發展到極致，設計的目標將轉向「預測」：像 Amazon 網站上可以預測想要購買的商品，或 Facebook 推播貼文那樣，在使用者開口前就知道答案，減少一切阻力。",{"type":20,"tag":43,"props":200,"children":201},{},[202,212,222],{"type":20,"tag":47,"props":203,"children":204},{},[205,210],{"type":20,"tag":51,"props":206,"children":207},{},[208],{"type":25,"value":209},"反思壓力與行動",{"type":25,"value":211},"：產生壓力與行動力，是身為人的基本特質。雖然我們追求極致流暢（Seamless），但適度的、有意義的摩擦，或許才是讓人感受到「自我掌控感」的關鍵。",{"type":20,"tag":47,"props":213,"children":214},{},[215,220],{"type":20,"tag":51,"props":216,"children":217},{},[218],{"type":25,"value":219},"消滅阻力的副作用",{"type":25,"value":221},"：當我們替生活發明了更便利的工具（如壞了完全不知如何修起的現代馬桶），我們也同時創造了「新的無知」。自動化消除了生活中的摩擦，卻也削弱了人類解決問題的基本能力。",{"type":20,"tag":47,"props":223,"children":224},{},[225,230],{"type":20,"tag":51,"props":226,"children":227},{},[228],{"type":25,"value":229},"AI 的假設牢籠",{"type":25,"value":231},"：AI 標榜「最了解你」，但這種極致的便利其實是將我們鎖在一個由過去數據編織成的「假設牢籠」裡。如果系統總是給我們「它以為我們想要的」，我們將永遠無法打破框架，去遇見那些意料之外的成長。",{"type":20,"tag":31,"props":233,"children":235},{"id":234},"數位時代的史金納箱變動獎勵下的情緒陷阱",[236],{"type":25,"value":237},"數位時代的史金納箱：變動獎勵下的情緒陷阱",{"type":20,"tag":21,"props":239,"children":240},{},[241],{"type":25,"value":242},"設計不僅在幫我們解決問題，有時也在製造「癮」。",{"type":20,"tag":43,"props":244,"children":245},{},[246,256],{"type":20,"tag":47,"props":247,"children":248},{},[249,254],{"type":20,"tag":51,"props":250,"children":251},{},[252],{"type":25,"value":253},"勾癮效應與變動獎勵",{"type":25,"value":255},"：書中將 FB等社群媒體比喻為現代的「史金納箱（Skinner Box）」。根據行為主義大師史金納的實驗，比起「每次按鈕都有食物」，「隨機、不可預測的獎勵」更能讓老鼠瘋狂按壓。",{"type":20,"tag":47,"props":257,"children":258},{},[259,264],{"type":20,"tag":51,"props":260,"children":261},{},[262],{"type":25,"value":263},"極端情緒與同溫層",{"type":25,"value":265},"：社群平台的「友善設計」透過變動回饋（Likes、通知）讓我們過度信任演算法。為了最大化參與度，系統傾向推播能觸發極端情緒（如憤怒或極度興奮）的內容，最終將我們困在強化偏見的同溫層中。",{"type":20,"tag":21,"props":267,"children":268},{},[269],{"type":25,"value":270},"雖然這本是2018出版的書，但放在現今AI科技發展的時代裡，許多觀點和問題被更加放大凸顯：介面零阻力的實現、機器包容時代下獨立思考的重要性，以及科技便利帶來的成癮性，在思考產品設計如何改善生活的同時，設計師的角色應從單純的介面美化轉向「行為編排者」。我們該學習將產品歷程視為一場談戀愛，利用情感連結來彌補複雜系統的回饋不足，設計不該是讓人退化的認知輪椅，而應是融入社會脈絡、賦予人類力量的望遠鏡，讓我們在享受自動化便利的同時，依然能保住身而為人的主動權與成長空間。",{"type":20,"tag":272,"props":273,"children":275},"h3",{"id":274},"source",[276],{"type":25,"value":277},"Source",{"type":20,"tag":21,"props":279,"children":280},{},[281,290],{"type":20,"tag":282,"props":283,"children":287},"a",{"href":284,"rel":285},"https:\u002F\u002Fwww.books.com.tw\u002Fproducts\u002F0010844948?srsltid=AfmBOorcS1hgpkQVaAR0XtJnDGjRamsZC7gzkhvxxq39gHRgNEH-GLKP",[286],"nofollow",[288],{"type":25,"value":289},"《我們的行為是怎樣被設計的》",{"type":20,"tag":282,"props":291,"children":294},{"href":292,"rel":293},"https:\u002F\u002Fwww.thenewslens.com\u002Farticle\u002F144141",[286],[295],{"type":25,"value":296},"《行為上癮》：史金納箱實驗能更進一步解釋，「按讚」為什麼讓人如此著迷 - TNL The News Lens 關鍵評論網",{"title":7,"searchDepth":298,"depth":298,"links":299},2,[300,301,302,303,304],{"id":33,"depth":298,"text":36},{"id":100,"depth":298,"text":103},{"id":143,"depth":298,"text":146},{"id":182,"depth":298,"text":185},{"id":234,"depth":298,"text":237,"children":305},[306],{"id":274,"depth":307,"text":277},3,"markdown","content:blog:book-user-friendly.md","content","blog\u002Fbook-user-friendly.md","blog\u002Fbook-user-friendly","md",1783431921183]