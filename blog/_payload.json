[{"data":1,"prerenderedAt":802},["ShallowReactive",2],{"blog-posts":3},[4,315],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"keywords":11,"robots":11,"date":12,"image":13,"tags":14,"body":17,"_type":309,"_id":310,"_source":311,"_file":312,"_stem":313,"_extension":314},"\u002Fblog\u002Fbook-user-friendly","blog",false,"","《我們的行為是怎樣被設計的》在機器與行為之間，編排一場人性的對話","前陣子剛讀完《我們的行為是怎樣被設計的》，我對「設計」這兩個字的理解被徹底重組，並給了我一個全新的視角：設計不是為了解決功能問題，而是為了解決「人與科技如何共存」的信任問題。","我們的行為是怎樣被設計的, UI\u002FUX, 產品設計","2026-04-12","\u002Fimages\u002Farticle\u002Farticle_book-user-friendly.png",[15,16],"產品設計","心理學",{"type":18,"children":19,"toc":298},"root",[20,27,31,38,43,99,105,114,119,142,148,158,181,187,195,200,233,239,244,267,272,279],{"type":21,"tag":22,"props":23,"children":24},"element","p",{},[25],{"type":26,"value":10},"text",{"type":21,"tag":28,"props":29,"children":30},"hr",{},[],{"type":21,"tag":32,"props":33,"children":35},"h2",{"id":34},"我們對機器的期待其實很擬人",[36],{"type":26,"value":37},"我們對機器的期待，其實很「擬人」",{"type":21,"tag":22,"props":39,"children":40},{},[41],{"type":26,"value":42},"書中指出「我們對機器的期待，非常符合我們對真人的期待」。就像當我們在執行複雜的 AI 自動化工作流程時，我們下意識會希望機器能「感應」到我們的意圖",{"type":21,"tag":44,"props":45,"children":46},"ul",{},[47,59,69,79,89],{"type":21,"tag":48,"props":49,"children":50},"li",{},[51,57],{"type":21,"tag":52,"props":53,"children":54},"strong",{},[55],{"type":26,"value":56},"心智模型（Mental Model）",{"type":26,"value":58},"：使用者不是在學功能，而是在建立對機器的想像。如果機器做得比你好，但做法跟你完全不同，那種「摩擦力」就是挫折感的來源。",{"type":21,"tag":48,"props":60,"children":61},{},[62,67],{"type":21,"tag":52,"props":63,"children":64},{},[65],{"type":26,"value":66},"社交禮貌",{"type":26,"value":68},"：產品不只是賣功能，而是一種社交。如果產品實現的跟我們想要的完全不同、沒有即時回饋，或在錯誤的時間打斷使用者，這在心理學上就是一種「失禮」。",{"type":21,"tag":48,"props":70,"children":71},{},[72,77],{"type":21,"tag":52,"props":73,"children":74},{},[75],{"type":26,"value":76},"信任累積在小事中",{"type":26,"value":78},"：就像人際關係一樣，機器的可靠性不是來自大功能，要讓人信任機器，必須讓人類感覺「機器知道我想做什麼」。這種安全感來自於精準的回饋機制，它像肢體語言一樣，在非字詞的層次上與使用者溝通。",{"type":21,"tag":48,"props":80,"children":81},{},[82,87],{"type":21,"tag":52,"props":83,"children":84},{},[85],{"type":26,"value":86},"彌補心智模型的不足",{"type":26,"value":88},"：當產品的回饋不足或邏輯（心智模型）太過複雜時，適當的情感連結（Emotional Connection）能成為最好的救火隊。",{"type":21,"tag":48,"props":90,"children":91},{},[92,97],{"type":21,"tag":52,"props":93,"children":94},{},[95],{"type":26,"value":96},"情感的高低起伏",{"type":26,"value":98},"：書中建議將產品歷程視為一場「談戀愛」。一段完整的關係不該是一條平淡的直線，而應該有情感的高低起伏與驚喜，以峰終定律來說更能增加產品的記憶點。這種情感上的滿足感，往往能讓使用者忽略技術上的微小瑕疵，與產品建立更深層的信任。",{"type":21,"tag":32,"props":100,"children":102},{"id":101},"隱喻是科技的降落傘讓陌生變得安全",[103],{"type":26,"value":104},"隱喻是科技的「降落傘」：讓陌生變得安全",{"type":21,"tag":106,"props":107,"children":108},"blockquote",{},[109],{"type":21,"tag":22,"props":110,"children":111},{},[112],{"type":26,"value":113},"發明任何東西，一定要用隱喻或透過隱喻來思考，隱喻是事物變美的關鍵。",{"type":21,"tag":22,"props":115,"children":116},{},[117],{"type":26,"value":118},"書中提到在我們的生活中，處處充滿會使我們感受擬人化的事物：看似人類表情的汽車車頭燈、前傾彷彿微笑歡迎的麥金塔電腦，結合擬人化的情感設計更使人與產品拉近距離",{"type":21,"tag":44,"props":120,"children":121},{},[122,132],{"type":21,"tag":48,"props":123,"children":124},{},[125,130],{"type":21,"tag":52,"props":126,"children":127},{},[128],{"type":26,"value":129},"橋接新舊世界",{"type":26,"value":131},"：設計師的工作就像是在冰冷的數位邏輯與人類的物理經驗間搭橋。為什麼第一代電腦要模仿「桌面」？因為我們需要熟悉的隱喻來克服對未知的恐懼，初期設計時可以藉由情緒版（mood board）釐清抽象情緒，並讓用戶喚起對某些事物的感受。",{"type":21,"tag":48,"props":133,"children":134},{},[135,140],{"type":21,"tag":52,"props":136,"children":137},{},[138],{"type":26,"value":139},"隱喻的演進",{"type":26,"value":141},"：雖然隱喻會隨著時間「死去」變成語言的一部分（如：存檔圖示是磁碟片），但它讓技術降落在人類的直覺上，當物理世界的舊隱喻失效時，我們如何創造新的行為模式，讓事情「不假思索」地發生？",{"type":21,"tag":32,"props":143,"children":145},{"id":144},"包容設計障礙不是人的問題是設計的問題",[146],{"type":26,"value":147},"包容設計：障礙不是人的問題，是「設計」的問題",{"type":21,"tag":22,"props":149,"children":150},{},[151,153],{"type":26,"value":152},"書中給了設計師一個沉重的社會責任：",{"type":21,"tag":52,"props":154,"children":155},{},[156],{"type":26,"value":157},"「大多數人口中的殘缺，其實是設計的問題。」",{"type":21,"tag":44,"props":159,"children":160},{},[161,171],{"type":21,"tag":48,"props":162,"children":163},{},[164,169],{"type":21,"tag":52,"props":165,"children":166},{},[167],{"type":26,"value":168},"邊緣設計的價值",{"type":26,"value":170},"：如果我們只為「理想中的正常人」設計，那其實是設計師的懶惰。以通用設計的概念，當我們開始考慮人類的極限、缺陷與容易出錯的本質，設計出的成品反而會對所有人（包含大眾）都更好用。",{"type":21,"tag":48,"props":172,"children":173},{},[174,179],{"type":21,"tag":52,"props":175,"children":176},{},[177],{"type":26,"value":178},"看見未來的人",{"type":26,"value":180},"：設計師被定義為「不能通靈，卻能看見未來的人」。我們的工作是重塑問題，並在事物發生前，就為未來的生活方式定調。",{"type":21,"tag":32,"props":182,"children":184},{"id":183},"零阻力的未來按鈕時代的終結",[185],{"type":26,"value":186},"零阻力的未來：按鈕時代的終結",{"type":21,"tag":106,"props":188,"children":189},{},[190],{"type":21,"tag":22,"props":191,"children":192},{},[193],{"type":26,"value":194},"容易和簡單並非一模一樣，探索什麼是真正簡單的東西，並付諸行動，是非常艱難的任務 ——杜威 John Dewey 經驗與教育 Experience and Education",{"type":21,"tag":22,"props":196,"children":197},{},[198],{"type":26,"value":199},"當科技發展到極致，設計的目標將轉向「預測」：像 Amazon 網站上可以預測想要購買的商品，或 Facebook 推播貼文那樣，在使用者開口前就知道答案，減少一切阻力。",{"type":21,"tag":44,"props":201,"children":202},{},[203,213,223],{"type":21,"tag":48,"props":204,"children":205},{},[206,211],{"type":21,"tag":52,"props":207,"children":208},{},[209],{"type":26,"value":210},"反思壓力與行動",{"type":26,"value":212},"：產生壓力與行動力，是身為人的基本特質。雖然我們追求極致流暢（Seamless），但適度的、有意義的摩擦，或許才是讓人感受到「自我掌控感」的關鍵。",{"type":21,"tag":48,"props":214,"children":215},{},[216,221],{"type":21,"tag":52,"props":217,"children":218},{},[219],{"type":26,"value":220},"消滅阻力的副作用",{"type":26,"value":222},"：當我們替生活發明了更便利的工具（如壞了完全不知如何修起的現代馬桶），我們也同時創造了「新的無知」。自動化消除了生活中的摩擦，卻也削弱了人類解決問題的基本能力。",{"type":21,"tag":48,"props":224,"children":225},{},[226,231],{"type":21,"tag":52,"props":227,"children":228},{},[229],{"type":26,"value":230},"AI 的假設牢籠",{"type":26,"value":232},"：AI 標榜「最了解你」，但這種極致的便利其實是將我們鎖在一個由過去數據編織成的「假設牢籠」裡。如果系統總是給我們「它以為我們想要的」，我們將永遠無法打破框架，去遇見那些意料之外的成長。",{"type":21,"tag":32,"props":234,"children":236},{"id":235},"數位時代的史金納箱變動獎勵下的情緒陷阱",[237],{"type":26,"value":238},"數位時代的史金納箱：變動獎勵下的情緒陷阱",{"type":21,"tag":22,"props":240,"children":241},{},[242],{"type":26,"value":243},"設計不僅在幫我們解決問題，有時也在製造「癮」。",{"type":21,"tag":44,"props":245,"children":246},{},[247,257],{"type":21,"tag":48,"props":248,"children":249},{},[250,255],{"type":21,"tag":52,"props":251,"children":252},{},[253],{"type":26,"value":254},"勾癮效應與變動獎勵",{"type":26,"value":256},"：書中將 FB等社群媒體比喻為現代的「史金納箱（Skinner Box）」。根據行為主義大師史金納的實驗，比起「每次按鈕都有食物」，「隨機、不可預測的獎勵」更能讓老鼠瘋狂按壓。",{"type":21,"tag":48,"props":258,"children":259},{},[260,265],{"type":21,"tag":52,"props":261,"children":262},{},[263],{"type":26,"value":264},"極端情緒與同溫層",{"type":26,"value":266},"：社群平台的「友善設計」透過變動回饋（Likes、通知）讓我們過度信任演算法。為了最大化參與度，系統傾向推播能觸發極端情緒（如憤怒或極度興奮）的內容，最終將我們困在強化偏見的同溫層中。",{"type":21,"tag":22,"props":268,"children":269},{},[270],{"type":26,"value":271},"雖然這本是2018出版的書，但放在現今AI科技發展的時代裡，許多觀點和問題被更加放大凸顯：介面零阻力的實現、機器包容時代下獨立思考的重要性，以及科技便利帶來的成癮性，在思考產品設計如何改善生活的同時，設計師的角色應從單純的介面美化轉向「行為編排者」。我們該學習將產品歷程視為一場談戀愛，利用情感連結來彌補複雜系統的回饋不足，設計不該是讓人退化的認知輪椅，而應是融入社會脈絡、賦予人類力量的望遠鏡，讓我們在享受自動化便利的同時，依然能保住身而為人的主動權與成長空間。",{"type":21,"tag":273,"props":274,"children":276},"h3",{"id":275},"source",[277],{"type":26,"value":278},"Source",{"type":21,"tag":22,"props":280,"children":281},{},[282,291],{"type":21,"tag":283,"props":284,"children":288},"a",{"href":285,"rel":286},"https:\u002F\u002Fwww.books.com.tw\u002Fproducts\u002F0010844948?srsltid=AfmBOorcS1hgpkQVaAR0XtJnDGjRamsZC7gzkhvxxq39gHRgNEH-GLKP",[287],"nofollow",[289],{"type":26,"value":290},"《我們的行為是怎樣被設計的》",{"type":21,"tag":283,"props":292,"children":295},{"href":293,"rel":294},"https:\u002F\u002Fwww.thenewslens.com\u002Farticle\u002F144141",[287],[296],{"type":26,"value":297},"《行為上癮》：史金納箱實驗能更進一步解釋，「按讚」為什麼讓人如此著迷 - TNL The News Lens 關鍵評論網",{"title":8,"searchDepth":299,"depth":299,"links":300},2,[301,302,303,304,305],{"id":34,"depth":299,"text":37},{"id":101,"depth":299,"text":104},{"id":144,"depth":299,"text":147},{"id":183,"depth":299,"text":186},{"id":235,"depth":299,"text":238,"children":306},[307],{"id":275,"depth":308,"text":278},3,"markdown","content:blog:book-user-friendly.md","content","blog\u002Fbook-user-friendly.md","blog\u002Fbook-user-friendly","md",{"_path":316,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":317,"description":318,"keywords":319,"date":320,"image":321,"tags":322,"body":325,"_type":309,"_id":799,"_source":311,"_file":800,"_stem":801,"_extension":314},"\u002Fblog\u002Fmarkdown-test","Markdown 完整語法測試文章","這是一份用於測試 Nuxt Content 渲染效果的全功能範例，包含 SEO、格式與組件。","Markdown, 語法測試, SEO","2024-02-18","\u002Fimages\u002Farticle\u002Farticle_test.jpg",[323,324],"Markdown","Frontend",{"type":18,"children":326,"toc":789},[327,364,369,406,409,415,421,428,431,436,444,475,483,502,510,546,549,554,562,565,570,589,610,613,619,624,730,741,744,750,768,776],{"type":21,"tag":22,"props":328,"children":329},{},[330,332,337,339,345,346,354,356,362],{"type":26,"value":331},"這裡是一段標準的文字內容。測試",{"type":21,"tag":52,"props":333,"children":334},{},[335],{"type":26,"value":336},"粗體 (Bold)",{"type":26,"value":338},"、",{"type":21,"tag":340,"props":341,"children":342},"em",{},[343],{"type":26,"value":344},"斜體 (Italic)",{"type":26,"value":338},{"type":21,"tag":52,"props":347,"children":348},{},[349],{"type":21,"tag":340,"props":350,"children":351},{},[352],{"type":26,"value":353},"粗斜體",{"type":26,"value":355}," 以及 ",{"type":21,"tag":357,"props":358,"children":359},"del",{},[360],{"type":26,"value":361},"刪除線 (Strikethrough)",{"type":26,"value":363},"。",{"type":21,"tag":22,"props":365,"children":366},{},[367],{"type":26,"value":368},"你可以檢查 HTML 屬性：",{"type":21,"tag":44,"props":370,"children":371},{},[372,386],{"type":21,"tag":48,"props":373,"children":374},{},[375,377,384],{"type":26,"value":376},"語言：",{"type":21,"tag":378,"props":379,"children":381},"code",{"className":380},[],[382],{"type":26,"value":383},"lang=\"zh-Hant-TW\"",{"type":26,"value":385}," (需在 nuxt.config 設定)",{"type":21,"tag":48,"props":387,"children":388},{},[389,391,397,399,405],{"type":26,"value":390},"SEO：檢查 Head 標